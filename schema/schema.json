{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "IO generator schema",
    "description": "FPGA IO signal descriptions for pin constraint and HDL generation",
    "type": "object",
    "properties": {
        "title": {
            "type": "string"
        },
        "part": {
            "type": "string"
        },
        "signals": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "direction": {
                        "$ref": "defs/direction.json"
                    },
                    "buffer": {
                        "$ref": "defs/buffer.json"
                    },
                    "instance": {
                        "$ref": "defs/instance.json"
                    },
                    "bank": {
                        "$ref": "defs/bank.json"
                    },
                    "iostandard": {
                        "$ref": "defs/iostandard.json"
                    },
                    "pins": {
                        "$ref": "defs/pins.json"
                    },
                    "pinset": {
                        "$ref": "defs/pinset.json"
                    },
                    "width": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "generate": {
                        "type": "boolean",
                        "default": true
                    },
                    "infer": {
                        "type": "boolean",
                        "default": false
                    },
                    "bypass": {
                        "type": "boolean",
                        "default": false
                    },
                    "comment": {
                        "type": "object",
                        "properties": {
                            "xdc": {
                                "type": "string"
                            },
                            "hdl": {
                                "type": "string"
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "allOf": [
                    {
                        "if": {
                            "required": [
                                "generate"
                            ],
                            "properties": {
                                "generate": {
                                    "const": false
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "name"
                            ]
                        },
                        "else": {
                            "if": {
                                "required": [
                                    "bypass"
                                ],
                                "properties": {
                                    "bypass": {
                                        "const": true
                                    }
                                }
                            },
                            "then": {
                                "required": [
                                    "name",
                                    "direction"
                                ]
                            },
                            "else": {
                                "required": [
                                    "name",
                                    "direction",
                                    "buffer"
                                ]
                            }
                        }
                    },
                    {
                        "not": {
                            "required": [
                                "infer",
                                "bypass"
                            ],
                            "properties": {
                                "infer": {
                                    "const": true
                                },
                                "bypass": {
                                    "const": true
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "required": [
                                "pins"
                            ],
                            "properties": {
                                "pins": {
                                    "type": "array"
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "width",
                                "iostandard"
                            ]
                        }
                    },
                    {
                        "if": {
                            "required": [
                                "pinset"
                            ],
                            "properties": {
                                "pinset": {
                                    "type": "object",
                                    "required": [
                                        "p"
                                    ],
                                    "properties": {
                                        "p": {
                                            "type": "array"
                                        }
                                    }
                                }
                            }
                        },
                        "then": {
                            "required": [
                                "width",
                                "iostandard"
                            ]
                        }
                    }
                ],
                "oneOf": [
                    {
                        "required": [
                            "pins"
                        ]
                    },
                    {
                        "required": [
                            "pinset"
                        ]
                    }
                ],
                "additionalProperties": false
            }
        },
        "banks": {
            "type": "object",
            "propertyNames": {
                "pattern": "^[0-9]+$"
            },
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "iostandard": {
                        "$ref": "defs/iostandard.json"
                    },
                    "performance": {
                        "$ref": "defs/performance.json"
                    }
                },
                "required": [
                    "iostandard",
                    "performance"
                ],
                "additionalProperties": false
            }
        }
    },
    "required": [
        "title",
        "part",
        "signals"
    ]
}
